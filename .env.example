# =============================================
# Terapeutas Agent — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================

# --- Claude API (LLM principal para gerar respostas) ---
ANTHROPIC_API_KEY=

# --- OpenAI (usado APENAS para gerar embeddings dos documentos) ---
OPENAI_API_KEY=

# --- Supabase (banco de dados PostgreSQL + pgvector + storage de PDFs) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Evolution API (conexão com WhatsApp, self-hosted) ---
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# --- Meta WhatsApp Cloud API (alternativa à Evolution API, integração direta) ---
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ID=
META_VERIFY_TOKEN=

# --- Asaas (gateway de pagamento para cobrança recorrente) ---
ASAAS_API_KEY=
# Token de segurança para validar webhooks do Asaas (configure em Asaas → Integrações → Webhooks)
ASAAS_WEBHOOK_TOKEN=

# --- Controle de acesso ---
# Contato do admin exibido quando usuário é bloqueado por violações
CONTATO_ADMIN=https://wa.me/5511999999999

# --- Aplicação ---
# Chave secreta para JWT e segurança geral (gere uma aleatória)
SECRET_KEY=
# URL de conexão direta com o banco (opcional, Supabase já cobre)
DATABASE_URL=
